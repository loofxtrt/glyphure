.highlighted-entry .glyphure-icon svg {
	/* isso colore só o ícone, não o texto do item inteiro na file tree */
	color: var(--color-accent) !important;
}

.highlighted-entry:hover .glyphure-icon svg {
	/* faz o highlight não sobreescrever a cor de hover no item da file tree */
    color: var(--color-hover-accent) !important;
}

