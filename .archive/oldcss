:root {
	--icon-size: 14px;
}

/* .nav-folder-title .glyphure-icon svg, .nav-file-title .glyphure-icon svg { */
.glyphure-icon, .glyphure-icon svg, .glyphure-icon * {
	width: var(--icon-size) !important;
	height: var(--icon-size) !important;
	min-width: var(--icon-size) !important;
	min-height: var(--icon-size) !important;
	max-width: var(--icon-size) !important;
	max-height: var(--icon-size) !important;

	/* centralização vertical */
	text-align: center !important;
	vertical-align: middle !important;

    /* distância entre o ícone e o texto do nome do arquivo/pasta */
    margin-right: 6px !important;
}

.glyphure-rule {
	background-color: var(--setting-items-background) !important;
	border-radius: var(--setting-items-radius) !important;
	margin-bottom: var(--size-4-2); /* o mesmo que o obsidian usa em setting-item */
}

.glyphure-rule > .setting-item {
	background-color: transparent !important;
	margin-top: 0;
	margin-bottom: 0;
}

