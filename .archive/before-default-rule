					break;
				case '_arquivo':
					glyphId = 'archive';
					break;
				case '_attachments':
					glyphId = 'link-2';
					break;
				case '_anexos':
					glyphId = 'link-2';
					break;
				case '_icons':
					glyphId = iconsDirectoryGlyph;
					break;
				case '_icones':
					glyphId = iconsDirectoryGlyph;
					break;
				case '_templates':
					//glyphId = 'pen-line';
					//glyphId = 'syringe';
					//glyphId = 'recycle';
					//glyphId = 'layout-template';
					//glyphId = 'text-cursor-input';
					//glyphId = 'clipboard-paste';
					glyphId = 'clipboard';
					//glyphId = 'clipboard-plus';
					//glyphId = 'clipboard-pen';
